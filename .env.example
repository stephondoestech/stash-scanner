# Scanner runtime
STASH_SCANNER_STASH_URL=http://localhost:9999
STASH_SCANNER_API_KEY=replace-me
# Preferred when the scanner and Stash see the same library paths.
STASH_SCANNER_WATCH_ROOTS_FROM_STASH=true
# Optional fallback if you want to manage paths directly in the scanner instead.
# STASH_SCANNER_WATCH_ROOTS=/mnt/user/media
STASH_SCANNER_STATE_PATH=data/state.json
# For Docker / Unraid, use /config/state.json and mount host appdata to /config.
STASH_SCANNER_DRY_RUN=true
STASH_SCANNER_DEBUG=false
STASH_SCANNER_POST_SCAN_TASKS=
# Required only if STASH_SCANNER_POST_SCAN_TASKS includes identify.
STASH_SCANNER_IDENTIFY_STASH_BOX_INDEXES=
STASH_SCANNER_IDENTIFY_STASH_BOX_ENDPOINTS=
STASH_SCANNER_IDENTIFY_SCRAPER_IDS=
STASH_SCANNER_POST_SCAN_CLEAN_DRY_RUN=false

# Control surface
STASH_SCANNER_CONTROL_BIND=127.0.0.1:8088
STASH_SCANNER_CONTROL_FALLBACK_BIND=127.0.0.1:8089

# Scheduling
STASH_SCANNER_INTERVAL=15m

# Retry policy
STASH_SCANNER_RETRY_MAX_ATTEMPTS=5
STASH_SCANNER_RETRY_INITIAL_BACKOFF=30s
STASH_SCANNER_RETRY_MAX_BACKOFF=15m
